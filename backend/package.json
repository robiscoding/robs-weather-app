{
    "name": "backend",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "tsx watch --env-file=.env  src/index.ts",
        "build": "tsc -p tsconfig.build.json",
        "start": "node dist/index.js --env-file=.env",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "tsc -p tsconfig.build.json --noEmit"
    },
    "dependencies": {
        "@robiscoding/shared": "workspace:*",
        "cors": "^2.8.6",
        "express": "^5.2.1",
        "express-rate-limit": "^8.3.2",
        "swagger-ui-express": "^5.0.1",
        "zod-openapi": "^5.4.6"
    },
    "devDependencies": {
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/node": "^24.10.1",
        "@types/supertest": "^6.0.3",
        "@types/swagger-ui-express": "^4.1.8",
        "supertest": "^7.1.4",
        "tsx": "^4.21.0",
        "typescript": "~5.9.3",
        "vitest": "^4.0.16"
    }
}